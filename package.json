{
  "name": "reactless-jsx",
  "version": "2.0.0",
  "description": "Compile JSX into a flat, runtime-agnostic JSXRoot object – no React required.",
  "main": "src/babel-plugin.js",
  "exports": {
    ".": "./src/babel-plugin.js",
    "./standalone": "./src/standalone.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/index.js",
    "babel": "npx babel test/fixture.jsx -o dis/output.js"
  },
  "keywords": [
    "jsx",
    "babel-plugin",
    "jsxroot",
    "compiler",
    "reactless",
    "template",
    "acorn"
  ],
  "author": "Mohammed Galal <mohammedgalal682@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mohammed-Galal/reactless-jsx.git"
  },
  "bugs": {
    "url": "https://github.com/Mohammed-Galal/reactless-jsx/issues"
  },
  "homepage": "https://github.com/Mohammed-Galal/reactless-jsx#readme",
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7"
  },
  "peerDependencies": {},
  "optionalDependencies": {
    "acorn": "^8.17.0",
    "acorn-jsx": "^5.3.2"
  },
  "dependencies": {
    "astring": "^1.9.0"
  }
}